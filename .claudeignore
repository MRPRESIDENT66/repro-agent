# Claude Code ignore — keep large, regenerated, or low-signal trees out of
# context. Source, oracles, tests, exec/verify/retrieval, and the reports stay
# visible; everything below is data, weights, vendored repos, or run artifacts.

# Python envs / caches
.venv/
.venv-*/
__pycache__/
*.pyc
.pytest_cache/

# Secrets
.env

# Large / regenerated trees (24万+ files each — never useful to scan wholesale)
workspaces/
repos/
data/
checkpoints/

# Per-run experiment artifacts (transcripts, traces, logs). The consolidated
# findings live in evals/FINAL_REPORT.md / RESULTS.md, not in these.
evals/runs/**/*.jsonl
evals/runs/**/*_rag_trace.md
evals/runs/**/*_transcript.jsonl
evals/runs/**/*_synthesis_transcript.jsonl
evals/runs/**/*_probe_trace.md
evals/runs/**/reproducer_public_log.txt
evals/runs/**/commands.sh
evals/runs/**/runtime_probes.*

# OS / IDE
.DS_Store
.idea/
