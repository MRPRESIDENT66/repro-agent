      "new": "def get_preprocessor_from_config(config_path):\n    \"\"\"Create TestStandardPreProcessor from a config file.\n\n    The config.yml files in checkpoint directories use a YAML tag that\n    yaml.safe_load cannot handle. We parse the file manually to extract\n    the preprocessor parameters.\n    \"\"\"\n    import yaml\n    with open(config_path, 'r') as f:\n        raw = yaml.safe_load(f)\n    # The file has a !!python/object/new tag; safe_load returns a dict\n    # with keys 'state' and 'dictitems'. The preprocessor params are\n    # under raw['state']['preprocessor'] or raw['dictitems']['preprocessor'].\n    # We need to find the preprocessor config dict.\n    if 'state' in raw and 'preprocessor' in raw['state']:\n        preproc_cfg = raw['state']['preprocessor']\n    elif 'dictitems' in raw and 'preprocessor' in raw['dictitems']:\n        preproc_cfg = raw['dictitems']['preprocessor']\n    else:\n        # Fallback: search for preprocessor key anywhere\n        preproc_cfg = None\n        for key in ('state', 'dictitems'):\n            if key in raw and isinstance(raw[key], dict):\n                for k, v in raw[key].items():\n                    if k == 'preprocessor':\n                        preproc_cfg = v\n                        break\n        if preproc_cfg is None:\n            raise ValueError(f'Could not find preprocessor config in {config_path}')\n    # preproc_cfg may itself be a dict with 'state' key (nested Config object)\n    if isinstance(preproc_cfg, dict) and 'state' in preproc_cfg:\n        preproc_cfg = preproc_cfg['state']\n    # Build a simple config-like object with the needed attributes\n    class SimpleConfig:\n        pass\n    cfg = SimpleConfig()\n    cfg.pre_size = preproc_cfg.get('pre_size', 32)\n    cfg.image_size = preproc_cfg.get('image_size', 32)\n    cfg.interpolation = preproc_cfg.get('interpolation', 'bilinear')\n    # Normalization: from dataset config or preprocessor config\n    # The normalization is stored under dataset.normalization or preprocessor.normalization\n    # In the config.yml, it's under state.dataset.normalization\n    if 'state' in raw and 'dataset' in raw['state']:\n        ds_cfg = raw['state']['dataset']\n        if isinstance(ds_cfg, dict) and 'normalization' in ds_cfg:\n            cfg.normalization = ds_cfg['normalization']\n        elif isinstance(ds_cfg, dict) and 'state' in ds_cfg and 'normalization' in ds_cfg['state']:\n            cfg.normalization = ds_cfg['state']['normalization']\n        else:\n            # Default CIFAR-10 normalization\n            cfg.normalization = [[0.4914, 0.4822, 0.4465], [0.2470, 0.2435, 0.2616]]\n    else:\n        cfg.normalization = [[0.4914, 0.4822, 0.4465], [0.2470, 0.2435, 0.2616]]\n    # Set mean and std attributes expected by TestStandardPreProcessor\n    cfg.mean = cfg.normalization[0]\n    cfg.std = cfg.normalization[1]\n    return TestStandardPreProcessor(cfg)"
