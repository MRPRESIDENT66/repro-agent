      "old": "def compute_auroc(id_scores, ood_scores):\n    \"\"\"Compute AUROC where higher score = more OOD-like (EBO convention).\"\"\"\n    scores = np.concatenate([id_scores, ood_scores])\n    labels = np.concatenate([np.zeros_like(id_scores), np.ones_like(ood_scores)])\n    \n    # Sort by score descending (higher score = more OOD)\n    order = np.argsort(-scores)\n    labels_sorted = labels[order]\n    \n    # True positive rate and false positive rate\n    tpr = np.cumsum(labels_sorted) / np.sum(labels_sorted)\n    fpr = np.cumsum(1 - labels_sorted) / np.sum(1 - labels_sorted)\n    \n    # AUROC via trapezoidal rule\n    auroc = np.trapz(tpr, fpr)\n    return auroc",
