      "new": "def get_preprocessor_from_config(config_path):\n    \"\"\"Create TestStandardPreProcessor from a config file.\n\n    The config.yml files in checkpoint directories use a YAML tag that\n    yaml.safe_load cannot handle. We parse the file manually to extract\n    the preprocessor parameters.\n    \"\"\"\n    import yaml\n    with open(config_path, 'r') as f:\n        raw = yaml.load(f, Loader=yaml.UnsafeLoader)\n    # Navigate through the pickled Config structure to get preprocessor params\n    # The file has state/dictitems nesting; preprocessor is under dictitems\n    preproc_cfg = raw['dictitems']['preprocessor']\n    # Build a simple dict with the needed keys for TestStandardPreProcessor\n    # The preprocessor config has state and dictitems; we need the actual values\n    # from the nested structure\n    preproc_state = preproc_cfg['state']\n    preproc_dictitems = preproc_cfg['dictitems']\n    # Merge state and dictitems, with dictitems taking precedence\n    merged = {}\n    merged.update(preproc_state)\n    merged.update(preproc_dictitems)\n    # Now get the dataset config for normalization, pre_size, img_size\n    dataset_cfg = raw['dictitems']['dataset']\n    dataset_state = dataset_cfg['state']\n    dataset_dictitems = dataset_cfg['dictitems']\n    dataset_merged = {}\n    dataset_merged.update(dataset_state)\n    dataset_merged.update(dataset_dictitems)\n    # Build a simple object with attribute access\n    class SimpleConfig:\n        def __init__(self, d):\n            self.__dict__.update(d)\n    # Create config with all needed fields\n    config_dict = {\n        'pre_size': dataset_merged['pre_size'],\n        'img_size': dataset_merged['image_size'],\n        'normalization': dataset_merged['normalization'],\n    }\n    config = SimpleConfig(config_dict)\n    return TestStandardPreProcessor(config)"
